{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "arcanedev/log-viewer": "^11.0",
        "barryvdh/laravel-dompdf": "^2.2",
        "doctrine/dbal": "^3.0",
        "guzzlehttp/guzzle": "^7.8",
        "kodeine/laravel-meta": "^2.2",
        "laravel-notification-channels/fcm": "^4.3",
        "laravel/framework": "^11.9",
        "laravel/jetstream": "^5.0",
        "laravel/octane": "^2.3",
        "laravel/pennant": "^1.7",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "midtrans/midtrans-php": "^2.6",
        "predis/predis": "^2.0",
        "ralphjsmit/livewire-urls": "^1.4",
        "shetabit/visitor": "^4.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-feed": "^4.5",
        "spatie/laravel-permission": "^6.25",
        "spatie/laravel-sitemap": "^7.0",
        "symfony/css-selector": "^7.4",
        "symfony/dom-crawler": "^7.4",
        "symfony/expression-language": "^7.4",
        "tightenco/ziggy": "^2.0",
        "vedmant/laravel-feed-reader": "^1.6",
        "webklex/laravel-pdfmerger": "^1.3",
        "yajra/laravel-datatables-html": "^11.0",
        "yajra/laravel-datatables-oracle": "^11.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.23",
        "laradumps/laradumps": "^5.3",
        "laradumps/laradumps-core": "^4.0",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "modules/"
        },
        "files": [
            "app/Helpers/Device.php",
            "app/Helpers/Inwords.php",
            "app/Helpers/Setting.php",
            "app/Helpers/BreakJson.php",
            "app/Helpers/Helper.php",
            "app/Helpers/Vacation.php",
            "app/Helpers/Postyear.php",
            "app/Helpers/Taxrate.php",
            "app/Helpers/Isurance.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-root-package-update": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": false,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.25"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
